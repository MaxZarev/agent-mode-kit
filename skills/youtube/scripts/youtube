#!/usr/bin/env zsh
SCRIPT_DIR="${0:A:h}"
VENV="$SCRIPT_DIR/venv"

if [[ ! -d "$VENV" ]]; then
    echo "Первый запуск: устанавливаю зависимости..." >&2
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install -q -r "$SCRIPT_DIR/requirements.txt"
fi

exec "$VENV/bin/python3" "$SCRIPT_DIR/youtube_core.py" "$@"
