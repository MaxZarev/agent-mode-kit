#!/usr/bin/env bash
# Собирает review-пакет: список коммитов, сводку по файлам и полный дифф с расширенным
# контекстом — в один файл, который критик читает за один вызов. Использование
# записанного per-этап BASE (а не HEAD~1) сохраняет все коммиты многокоммитного этапа.
#
# Адаптация superpowers subagent-driven-development: артефакты под .spec-first/sdd/;
# гард на отсутствие git — без репозитория печатает уведомление и выходит с кодом 0,
# а критику дают произведённые этапом файлы напрямую (вместо диффа).
#
# Usage: review-package BASE HEAD [SLUG]
#   SLUG (опц.) — папка прогона: пакет ложится в <корень>/.spec-first/sdd/<SLUG>/
# Default (без SLUG): <корень>/.spec-first/sdd/review-<base7>..<head7>.diff
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "usage: review-package BASE HEAD [SLUG]" >&2
  exit 2
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "no git repository — skipping review package; give the critic the stage's produced files directly" >&2
  exit 0
fi

base=$1
head=$2
slug="${3:-}"

git rev-parse --verify --quiet "$base" >/dev/null || { echo "bad BASE: $base" >&2; exit 2; }
git rev-parse --verify --quiet "$head" >/dev/null || { echo "bad HEAD: $head" >&2; exit 2; }

# через bash, чтобы не зависеть от exec-бита (zip на Windows его не сохраняет)
dir=$(bash "$(cd "$(dirname "$0")" && pwd)/sdd-workspace" ${slug:+"$slug"})
out="$dir/review-$(git rev-parse --short "$base")..$(git rev-parse --short "$head").diff"

{
  echo "# Review package: ${base}..${head}"
  echo
  echo "## Commits"
  git log --oneline "${base}..${head}"
  echo
  echo "## Files changed"
  git diff --stat "${base}..${head}"
  echo
  echo "## Diff"
  git diff -U10 "${base}..${head}"
} > "$out"

commits=$(git rev-list --count "${base}..${head}")
echo "wrote ${out}: ${commits} commit(s), $(wc -c < "$out" | tr -d ' ') bytes"
