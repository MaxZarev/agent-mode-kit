# Get an API key at https://app.upload-post.com/ → Settings → API
# Free plan allows 10 uploads per month.
API_KEY=your-upload-post-api-key-here

# Base URL for the Upload-Post API. Override only if Upload-Post changes it.
BASE_URL=https://api.upload-post.com/api

# Default profile username (must match a profile you connected in the Upload-Post UI).
# Override per-call with --user <username>. Leave as "default" if unsure.
DEFAULT_USER=default
