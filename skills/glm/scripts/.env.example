# Z.ai API key (GLM Coding Plan) for the research MCP servers used by the GLM
# worker: web search (web_search_prime), web reader (web_reader), and zread
# (GitHub repo interrogation).
#
# This MUST be the SAME key you set with `opencode auth login` (Z.AI Coding Plan).
# OpenCode reads it via {env:ZAI_API_KEY} in scripts/opencode.json — the key is
# never hardcoded in the config or the skill.
#
# Setup: copy this file to `.env` in the same directory and put the real key in.
#   cp .env.example .env
# `.env` is git-ignored.
ZAI_API_KEY=your-zai-api-key-here

# Fallback web tools for the GLM worker (used when the zai-* servers fail with
# 429 / timeouts).
# Tavily: web search / extract — https://tavily.com (~1000 credits/mo free).
TAVILY_API_KEY=your-tavily-api-key-here
# Firecrawl: page reading / scraping — https://firecrawl.dev (~1000 pages/mo free).
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
